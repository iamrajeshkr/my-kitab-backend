# Bingent API — copy to .env and fill in. NEVER commit the real .env.
NODE_ENV=development
PORT=8787

# Supabase (same project as the content tables)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=ey...                # anon/public key (safe for clients)
SUPABASE_SERVICE_KEY=ey...             # service_role — server only, bypasses RLS
SUPABASE_JWT_SECRET=your-jwt-secret    # Settings → API → JWT Secret (for local verify)

# LLM — keys live ONLY here, never in the Expo client.
GEMINI_API_KEY=AIza...
CHAT_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
